{
    "build_type": "app",

    "c_compiler_path": "auto",
    "c_standard": 17,
    "c_standard_required": true,
    "c_extensions": false,

    "cpp_compiler_path": "auto",
    "cpp_standard": 20,
    "cpp_standard_required": true,
    "cpp_extensions": false,

    "cmake_generator": "Ninja",
    "cmake_compile_definitions":
    {
        "def":
        [
            "DEF_1",
            "DEF_2"
        ],

        "val":
        [
            ["DEF_VAL_EXAMPLE_1", "\"string\""],
            ["DEF_VAL_EXAMPLE_2", "value"]
        ]
    },

    "project_name": "your_project_name",
    "project_version":
    {
        "major": 0,
        "minor": 0,
        "patch": 0
    }
}
