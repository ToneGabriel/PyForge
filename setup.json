{
    "project_settings":
    {
        "root": "path\\to\\your\\project\\root\\folder",
        "build": "app",
        "version":
        {
            "major": 0,
            "minor": 0,
            "patch": 0
        }
    },

    "c_settings":
    {
        "compiler_path": "path\\to\\your\\c\\compiler",
        "compiler_extensions_required": false,
        "language_standard": 17,
        "language_standard_required": true
    },

    "cpp_settings":
    {
        "compiler_path": "path\\to\\your\\cpp\\compiler",
        "compiler_extensions_required": false,
        "language_standard": 20,
        "language_standard_required": true
    },

    "cmake_settings":
    {
        "generator": "Ninja",
        "compile_definitions":
        [
            ["DEF_EXAMPLE", ""],
            ["DEF_VAL_EXAMPLE", "value"],
            ["DEF_STR_EXAMPLE", "\"string\""]
        ]
    }
}